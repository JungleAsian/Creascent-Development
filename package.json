{
  "name": "docmee",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @docmee/api dev",
    "typecheck": "pnpm -r --filter @docmee/* typecheck",
    "lint": "pnpm -r --filter @docmee/* lint",
    "test": "pnpm -r --filter @docmee/* test",
    "build": "pnpm -r --filter @docmee/* build",
    "tool": "pnpm --dir tools tool"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "eslint": "^9.5.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "overrides": {
      "google-auth-library": "10.7.0"
    }
  }
}
