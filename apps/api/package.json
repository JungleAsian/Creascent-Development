    "@fastify/sensible": "^5.5.0",
    "dotenv": "^16.4.5",
    "fast-jwt": "^6.2.4",
    "fastify": "^4.28.0",
    "ioredis": "5.10.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
