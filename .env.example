# ============================================================
# Docmee Product — Local Development Environment
# Copy to .env and fill values for your local setup.
# Never commit .env with real credentials.
# ============================================================

NODE_ENV=development
API_PORT=3001
APP_URL=http://localhost:3000
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Redis >= 5.0 required (BullMQ). `docker compose` provides redis:7-alpine.
REDIS_URL=redis://localhost:6379
LLM_STUB=true
WEBHOOK_TARGET=http://localhost:3001/webhook/whatsapp

# --- Production deployment (set these in .env.production on the VPS) ---
# Comma-separated origins the API trusts in PRODUCTION (the panel's public URL).
# In production ONLY this allowlist is accepted — if unset, the API blocks the
# panel via CORS. e.g. CORS_ORIGINS=https://app.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Baked into the inboxos bundle at BUILD time. Set this BEFORE `next build` if the
# API is not reachable at <panel-host>:3001 (e.g. behind a reverse proxy or a
# separate domain like https://api.yourdomain.com). Leave blank for the same-host
# fallback. NEXT_PUBLIC_API_URL=https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Meta / WhatsApp (filled in P04+)
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_DEFAULT_ACCESS_TOKEN=

# AI Providers (filled in P05+)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Notifications (filled in P06+)
RESEND_API_KEY=
EMAIL_FROM=

# Google Calendar OAuth (filled in P07+)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Auth (filled in P03+)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Feature flags (Req 40). Off unless set to 1/true/yes/on (case-insensitive).
FEATURE_ADVANCED_ANALYTICS=false
