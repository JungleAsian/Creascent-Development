# Normalize all text files to LF in the repo and the working tree, so files
# committed from Windows never carry CRLF. A CRLF in a shell script breaks on the
# Linux VPS with `bad interpreter: /bin/bash^M`.
* text=auto eol=lf

# Scripts / config that MUST be LF on Linux.
*.sh   text eol=lf
*.bash text eol=lf
*.cjs  text eol=lf
*.mjs  text eol=lf

# Binary assets — never convert.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
