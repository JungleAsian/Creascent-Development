# ============================================================
# Docmee DevTools Setup
# Copy this file to .env.tools, then fill only the services you use.
# Keep real keys private. Do not commit .env.tools.
# ============================================================


# ============================================================
# 1. Local DevTools App
# Required for the desktop tool and dashboard to run on this computer.
# ============================================================
TOOLS_DB_URL=http://localhost:54321
TOOLS_DB_SERVICE_KEY=your-local-service-key
MONOREPO_ROOT=../
NEXT_PUBLIC_DASHBOARD_PORT=4000
WEBHOOK_TARGET=http://localhost:3001/webhook/whatsapp
DEV_LICENSE_SIGNING_KEY=dev-local-signing-key


# ============================================================
# 2. Discord Notifications
# Optional. Fill these if you want DevTools to post messages to Discord.
# Provider page: https://discord.com/developers/applications
# Channel ID help: https://support.discord.com/hc/en-us/articles/206346498
# ============================================================
DISCORD_BOT_TOKEN=
DISCORD_MESSAGING_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_CRITICAL_CHANNEL_ID=
DISCORD_UPDATE_CHANNEL_ID=
DISCORD_APPROVAL_CHANNEL_ID=
DISCORD_STACK_CHANNEL_ID=1516646257500749856


# ============================================================
# 3. Notion Sync
# Optional but recommended. Used for prompts, build control, and docs sync.
# Provider page: https://www.notion.so/my-integrations
# ============================================================
NOTION_API_KEY=
NOTION_PROMPTS_DB_ID=38241c470daf81a8b44ef53543e6bb45
NOTION_BUILD_CONTROL_DB_ID=
NOTION_CLAUDE_MD_PAGE_ID=38141c470daf81c980ebf3beac2ce413


# ============================================================
# 4. Build Safety Controls
# Local development switches and guardrails.
# ============================================================
GATES_STRICT=false
COST_ALERT_THRESHOLD_USD=10
CLAUDE_SESSION_PAUSE_PERCENT=95
CLAUDE_SESSION_TOKEN_LIMIT=


# ============================================================
# 5. Supabase Local Database
# Used by local development and setup checks.
# Provider docs: https://supabase.com/docs/guides/local-development/cli/getting-started
# ============================================================
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ============================================================
# 6. AI Providers
# Fill only the providers you plan to use.
# Anthropic: https://console.anthropic.com/api-keys
# OpenAI: https://platform.openai.com/api-keys
# Google Gemini: https://aistudio.google.com/app/apikey
# Mistral: https://console.mistral.ai/api-keys
# DeepSeek: https://platform.deepseek.com/api_keys
# xAI Grok: https://console.x.ai
# ============================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBEDDING_KEY=
GOOGLE_GEMINI_API_KEY=
MISTRAL_API_KEY=
CUSTOM_AI_API_KEY=
CUSTOM_AI_BASE_URL=
CUSTOM_AI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com


# ============================================================
# 7. Stack Intelligence
# Optional. Used by /cost -> Stack Intelligence and Discord stack updates.
# STACK_NEWS_SOURCE can be: grok, claude, or both
# ============================================================
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-3
STACK_NEWS_SOURCE=both


# ============================================================
# 8. Voice, Email, Calendar
# Optional product integrations.
# Deepgram: https://console.deepgram.com
# Resend: https://resend.com/api-keys
# Google Cloud OAuth: https://console.cloud.google.com/apis/credentials
# ============================================================
DEEPGRAM_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback


# ============================================================
# 9. WhatsApp / Meta
# Optional until WhatsApp webhook testing and Meta approval.
# Provider page: https://developers.facebook.com
# ============================================================
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_DEFAULT_ACCESS_TOKEN=


# ============================================================
# 10. Runtime, Auth, License
# Local product runtime settings.
# ============================================================
REDIS_URL=redis://localhost:6379
JWT_SECRET=
JWT_REFRESH_SECRET=
LICENSE_SERVER_URL=
LICENSE_PUBLIC_KEY=
APP_URL=http://localhost:3000
APP_VERSION=0.1.0
API_PORT=3001
NODE_ENV=development
LLM_STUB=true
SERVER_ID=local-dev


# ============================================================
# 11. GitHub
# Used by phase auto-commit, auto-push, and deployment.
# Token page: https://github.com/settings/tokens
# ============================================================
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_REPO=git@github.com:yourorg/docmee.git
GITHUB_BRANCH=main


# ============================================================
# 12. VPS / Hostinger Deployment
# Optional until deployment. VPS_USER is usually root during setup.
# ============================================================
VPS_HOST=
VPS_USER=root
VPS_SSH_KEY_PATH=~/.ssh/id_ed25519
VPS_DEPLOY_PATH=/var/www/docmee
VPS_DOMAIN=yourdomain.com
ENV_PRODUCTION_PATH=.env.production
PM2_ECOSYSTEM_FILE=ecosystem.config.cjs
