{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["cli/src/**/*", "eslint/src/**/*", "discord/src/**/*", "sentinel/**/*.ts"],
  "exclude": ["node_modules", "dist", "dashboard", "app"]
}
