{
  "build": {
    "beforeDevCommand": "cd ../dashboard && pnpm dev",
    "devPath": "http://localhost:4000",
    "distDir": "../dashboard/.next"
  },
  "package": {
    "productName": "Docmee DevTools",
    "version": "0.1.0"
  },
  "tauri": {
    "bundle": {
      "identifier": "com.docmee.devtools",
      "icon": ["icons/32x32.png", "icons/128x128.png"]
    },
    "windows": [
      {
        "title": "Docmee DevTools",
        "width": 1280,
        "height": 800,
        "url": "http://localhost:4000",
        "visible": true
      }
    ],
    "systemTray": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "allowlist": {
      "shell": {
        "all": true,
        "execute": true,
        "open": true
      },
      "fs": {
        "all": true
      },
      "notification": {
        "all": true
      }
    }
  }
}
